# Supabase — copy from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Mapbox — https://account.mapbox.com/access-tokens/ (used for lounge detail page map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Google Maps — https://console.cloud.google.com (enable Maps JavaScript API + Places API)
# Used for interactive terminal navigation maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# AeroDataBox via RapidAPI — https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Free tier: 2,000 requests/day
AERODATABOX_API_KEY=your-rapidapi-key-here

# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role key — server-side admin operations.
# Get from Supabase Settings > API > Project API keys > service_role.
# NEVER expose to client. Used in scripts/ and any server-only admin routes.
SUPABASE_SERVICE_KEY=sb_secret_...

# Sentry — error monitoring. Get from sentry.io > Settings > Client Keys (DSN).
# When set, errors are reported in production. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
# Optional — sourcemap upload during build (only needed if you want decoded stack traces)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
